VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site key for this deployment (must exist in the sites table)
CMS_SITE_KEY=demo

# Optional: future CI publish webhook (stub only — not called in v1)
# CMS_PUBLISH_WEBHOOK_URL=https://example.com/hooks/publish

# E2E only — optional; auto-links editor to site_members (skip if you provision manually)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# E2E editor (must exist in Supabase Auth; must be in site_members for the CMS_SITE_KEY site)
E2E_EDITOR_EMAIL=editor@example.com
E2E_EDITOR_PASSWORD=your-test-password

# E2E only — authenticated user who is NOT in site_members (same password as editor)
E2E_NO_SITE_EMAIL=bohdan.anderson+no-site@gmail.com
