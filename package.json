{
  "name": "ghots-cms",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "server": "python3 -m http.server 8000 --directory dist",
    "static": "npm run generate && npm run server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:videos": "E2E_VIDEO=1 PLAYWRIGHT_BROWSERS_PATH=0 playwright test && playwright show-report",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --ui",
    "test:e2e:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "nuxt": "^4.4.5",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^25.9.1",
    "dotenv": "^16.4.7",
    "prettier": "^3.8.3"
  }
}
