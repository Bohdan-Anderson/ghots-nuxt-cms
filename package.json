{
  "name": "ghots-cms",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "server": "python3 -m http.server 8000 --directory dist",
    "static": "npm run generate && npm run server",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "nuxt": "^4.4.5",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
