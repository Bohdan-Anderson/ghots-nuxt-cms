{
  "name": "ghots-cms",
  "type": "module",
  "private": true,
  "workspaces": [
    "demo",
    "examples/minimal",
    "packages/nuxt-cms"
  ],
  "scripts": {
    "build": "npm run build -w ghots-cms-demo",
    "dev": "npm run dev -w ghots-cms-demo",
    "dev:minimal": "npm run dev -w ghots-cms-minimal",
    "generate": "npm run generate -w ghots-cms-demo",
    "publish:static": "npm run publish:static -w ghots-cms-demo",
    "preview": "npm run preview -w ghots-cms-demo",
    "postinstall": "npm run postinstall -w ghots-cms-demo",
    "static": "npm run static -w ghots-cms-demo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test -w ghots-nuxt-cms && npm run test:e2e",
    "test:unit": "npm run test -w ghots-nuxt-cms",
    "publish:package": "npm publish -w ghots-nuxt-cms",
    "test:e2e": "npm run test:e2e -w ghots-cms-demo",
    "test:e2e:videos": "npm run test:e2e:videos -w ghots-cms-demo",
    "test:e2e:ui": "npm run test:e2e:ui -w ghots-cms-demo",
    "test:e2e:install": "npm run test:e2e:install -w ghots-cms-demo"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
